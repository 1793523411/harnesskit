{
  "name": "@harnesskit/adapter-openai-agents",
  "version": "0.0.0",
  "description": "L2 adapter — bridges OpenAI Agents SDK tracing/hooks to harnesskit events",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@harnesskit/core": "workspace:*"
  },
  "peerDependencies": {
    "@openai/agents": "*"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@openai/agents": "^0.8.5"
  }
}
