{
  "name": "@harnesskit/examples",
  "version": "0.0.0",
  "private": true,
  "description": "Runnable demonstrations of the harnesskit SDK",
  "type": "module",
  "scripts": {
    "quickstart": "tsx src/quickstart.ts",
    "openai-quickstart": "tsx src/openai-quickstart.ts",
    "policy-and-eval": "tsx src/policy-and-eval.ts",
    "replay-eval": "tsx src/replay-eval.ts",
    "integration-volcengine": "tsx src/integration-volcengine.ts",
    "integration-real-api": "tsx src/integration-real-api.ts",
    "showcase": "tsx src/showcase-deny-recovery.ts",
    "showcase-tokens": "tsx src/showcase-token-budget.ts",
    "showcase-args": "tsx src/showcase-arg-regex.ts",
    "showcase-hostname": "tsx src/showcase-hostname.ts",
    "showcase-pii": "tsx src/showcase-pii.ts",
    "showcase-pii-redact": "tsx src/showcase-pii-redact.ts",
    "showcase-rewriter-chain": "tsx src/showcase-rewriter-chain.ts",
    "showcase-sign-request": "tsx src/showcase-sign-request.ts",
    "showcase-vertex-claude": "tsx src/showcase-vertex-claude.ts",
    "showcase-bedrock": "tsx src/showcase-bedrock.ts",
    "showcase-multi-tenant": "tsx src/showcase-multi-tenant.ts",
    "showcase-runner": "tsx src/showcase-runner.ts",
    "showcases": "pnpm showcase && pnpm showcase-tokens && pnpm showcase-args && pnpm showcase-hostname && pnpm showcase-pii && pnpm showcase-pii-redact && pnpm showcase-rewriter-chain && pnpm showcase-sign-request && pnpm showcase-vertex-claude && pnpm showcase-bedrock && pnpm showcase-multi-tenant && pnpm showcase-runner",
    "demo:reasoning": "tsx --env-file=.env src/demos/01-reasoning-showdown.ts",
    "demo:cross-provider-tools": "tsx --env-file=.env src/demos/02-cross-provider-tools.ts",
    "demo:cost": "tsx --env-file=.env src/demos/03-cost-tracking.ts",
    "demo:otel": "tsx --env-file=.env src/demos/04-otel-console.ts",
    "demo:trace-file": "tsx --env-file=.env src/demos/05-trace-to-file.ts",
    "demo:replay": "tsx --env-file=.env src/demos/06-replay-strict.ts",
    "demo:approval": "tsx --env-file=.env src/demos/07-approval-stdin.ts",
    "demo:concurrent": "tsx --env-file=.env src/demos/08-concurrent-stress.ts",
    "demo:image": "tsx --env-file=.env src/demos/09-multimodal-image.ts",
    "demo:long-context": "tsx --env-file=.env src/demos/10-long-context.ts",
    "demo:codex": "tsx --env-file=.env src/demos/11-codex-agent.ts",
    "demo:streaming": "tsx --env-file=.env src/demos/12-streaming-runner.ts",
    "all": "pnpm quickstart && pnpm openai-quickstart && pnpm policy-and-eval && pnpm replay-eval",
    "typecheck": "tsc --noEmit",
    "build": "echo 'examples are run with tsx, no build needed'",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@harnesskit/core": "workspace:*",
    "@harnesskit/policy": "workspace:*",
    "@harnesskit/eval": "workspace:*",
    "@harnesskit/provider-fetch": "workspace:*",
    "@harnesskit/runner": "workspace:*",
    "@harnesskit/otel": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
