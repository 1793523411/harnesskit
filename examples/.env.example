# Copy this to .env and fill in the keys you have access to.
# .env is gitignored. NEVER commit real keys.
#
# Run a demo with:  pnpm --filter @harnesskit/examples demo:reasoning
# (the package.json scripts pass --env-file=.env to tsx)

# ── Volcengine (DeepSeek + Doubao via Volcengine; OpenAI-compat) ─────
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_HOST=ark.cn-beijing.volces.com
VOLCENGINE_REASONING_MODEL=ep-m-20260227190842-nrldn
VOLCENGINE_CODE_MODEL=ep-m-20260227191724-kpnmp
VOLCENGINE_MINI_MODEL=doubao-seed-2-0-mini-260215
VOLCENGINE_FAST_MODEL=deepseek-v3-2-251201

# ── DeepSeek direct (OpenAI-compat) ──────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_HOST=api.deepseek.com
DEEPSEEK_REASONING_MODEL=deepseek-reasoner
DEEPSEEK_CHAT_MODEL=deepseek-chat

# ── Polo gateway: Gemini (OpenAI-compat) ─────────────────────────────
POLO_GEMINI_API_KEY=
POLO_GEMINI_BASE_URL=https://poloai.top/v1
POLO_GEMINI_HOST=poloai.top
POLO_GEMINI_THINKING_MODEL=gemini-3-flash-preview-thinking
POLO_GEMINI_FAST_MODEL=gemini-3-flash-preview

# ── Polo gateway: GPT (OpenAI-compat) ────────────────────────────────
POLO_GPT_API_KEY=
POLO_GPT_BASE_URL=https://poloai.top/v1
POLO_GPT_HOST=poloai.top
POLO_GPT_MODEL=gpt-5
POLO_GPT_MINI=gpt-5-mini

# ── Polo gateway: Claude (Anthropic-messages) ────────────────────────
POLO_CLAUDE_API_KEY=
POLO_CLAUDE_BASE_URL=https://poloai.top
POLO_CLAUDE_HOST=poloai.top
POLO_CLAUDE_THINKING_MODEL=claude-sonnet-4-6-thinking
POLO_CLAUDE_FAST_MODEL=claude-sonnet-4-20250514

# ── MiniMax (Anthropic-messages) ─────────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_HOST=api.minimaxi.com
MINIMAX_FAST_MODEL=MiniMax-M2.7-highspeed

# ── OpenAI direct ────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_HOST=api.openai.com
OPENAI_NANO_MODEL=gpt-5.4-nano
OPENAI_MINI_MODEL=gpt-5.4-mini
